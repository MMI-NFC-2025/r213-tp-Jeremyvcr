---
import Layout from "../../layouts/Layout.astro";
import { getOffres } from "../../backend.mjs";
import OffreCard from "../../components/OffreCard.astro";

const offres = await getOffres();
---

<Layout titre="Offres">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold">Toutes les maisons</h1>
    <a href="/favoris" class="flex items-center gap-2 bg-yellow-50 border border-yellow-300 text-yellow-700 px-4 py-2 rounded-lg font-medium hover:bg-yellow-100 transition-colors">
      ⭐ Voir mes favoris
    </a>
  </div>

  {offres.length > 0 ? (
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {offres.map((offre) => (
        <OffreCard offre={offre} />
      ))}
    </div>
  ) : (
    <p class="text-gray-500">Aucune maison disponible.</p>
  )}
</Layout>