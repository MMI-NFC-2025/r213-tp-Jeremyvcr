---
import Layout from "../../layouts/Layout.astro";
import { getAgents } from "../../backend.mjs";

const agents = await getAgents();
---

<Layout titre="Agents">
  <h1 class="text-3xl font-bold mb-8">Liste des agents</h1>

  {agents.length > 0 ? (
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {agents.map((agent) => (
        <a
          href={`/agents/${agent.id}`}
          class="block bg-white p-6 rounded-xl shadow hover:shadow-lg transition-shadow"
        >
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-blue-600 flex items-center justify-center text-white font-bold text-lg shrink-0">
              {agent.Email[0].toUpperCase()}
            </div>
            <div>
              <p class="font-semibold text-slate-900">{agent.Email}</p>
            </div>
          </div>
        </a>
      ))}
    </div>
  ) : (
    <p>Aucun agent disponible.</p>
  )}
</Layout>